#!/bin/bash

source /scripts/lib/scriptbootstrapper.bsh "$@" --needs-sudo

sudo apt-get update
sudo apt-get -y full-upgrade
sudo apt-get -y dist-upgrade
sudo apt-get -y autoremove
if [[ -n $(dpkg --list |grep "^rc" | cut -d " " -f 3) ]]; then
	dpkg --list |grep "^rc" | cut -d " " -f 3 | xargs sudo dpkg --purge
fi
info 3 System updated and packages cleaned.
