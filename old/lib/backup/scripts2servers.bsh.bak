#!/bin/bash
#ToDo: Rewrite to update disks as well.
#backup scripts
#For each host:
# ssh /scripts/scripts-from-disks(-test)
# ssh copy crontab
# ssh /scripts/script-reloader
title="copies script to the other servers and make a backup on services-lxc"
#defaults
user=user
helptext="copies scripts to the other servers
 requires root priviledges
 copies just to other test-servers when executed on a test-server
 prints a warning when not executed on disks*
 usage: "$0" [options]
  e.g.: "$0" 
           copies the scripts to the other servers on the network
        "$0" -u testuser -t testserver
           copies the scripts to testserver using its user testuser
 Options:
  -t --target [target] target machine name, defaults to array other_machines
     --test            test the basics and exit
  -u --user [username] username, defaults to user"
# - uses sudo joints to minimize password inputs # ssh -tt user@rec-01-test-VM "sudo -- bash -c 'cat /etc/machinename && ls -la / '"
# - has no password automation. The following has been tried
#   - read -s -p "Password: " pw #reads password and stores it in variable pw without showing it: works
#   - send password via echo pipe: shows the password in the local bash history
#     echo "$pw"  | ssh -tt user@rec-01-test-VM "sudo -kS cat /etc/hostname"
#     - send output to null: hides the commands output as well
#     - {
#       echo "$pw"  | ssh -tt user@rec-01-test-VM "sudo -kS cat /etc/machinename"
#       } &> /dev/null
#       doesn't show the output at all but also hides the password.
#   - edit remote sudoers file to not require sudo for a special ssh user (not tested): should work, but seems to much of security risk and effort

#parametrization and variables
arglongnames=( target user)
argshortnames=(t      u   )
argtypes=(     P      P   )
source /scripts/lib/scriptbootstrapper.bsh "$@" --needssudo --lock
source /scripts/lib/parameters.bsh servers
source /scripts/lib/call.bsh
if [[ -z "$target" ]]; then
	 targets=( "${other_servers[@]}" )
else
	 targets=( "$target" )
fi

scripts=/scripts
backup=/var/scripts/backup #scripts subfolder necessary because parent folders need have the same name and wildcards do not work with rsync --delete
inbox=/var/scripts/inbox

chown -R root:root $scripts

#check if the script is running on a main machine
if [[ ! $hostname == *"disks"* ]]; then
	 echo "======================================================================================="
	 echo "   Warning! Script runs on "$hostname" and will copy from "$hostname" to the other servers!"
	 echo "======================================================================================="
	 read -p "Press enter to continue. Strg+C to cancel"
fi

echo local backup
call /scripts/backup.bsh /scripts /var/scripts/scripts-backup

echo "-----------------------------------"
echo " backup to scriptuser@services-lxc "
echo "-----------------------------------"
call /scripts/backup.bsh "/scripts" "scriptuser@services-lxc:/home/scriptuser/scripts-backup"

echo .
echo "source machine:   " "$hostname"
echo "target machine(s):" "${other_servers[@]}"
echo .

#perform local backup (inbox is the wrong name, but we use it for consistencies sake)
[[ -d $backup ]] || sudo mkdir -p $backup #check if folder exists
[[ -d $inbox ]] || sudo mkdir -p $inbox #check if folder exists
sudo rsync -avx --delete --exclude=*.swp --exclude="__pycache__" --exclude=*"~"* --exclude *"#"* --backup --backup-dir=$backup $scripts/ $inbox/

/scripts/service-reloader.bsh
cp -u /scripts/lib/crontab /etc/crontab
sudo -u user76 lxc-attach -n services-lxc cp /scripts/crontab /etc/crontab || true ##ToDo: rewrite properly.
sudo -u user lxc-attach -n services-lxc-test cp /scripts/crontab /etc/crontab || true
sudo -u user76 lxc-attach -n webserver-lxc cp /scripts/crontab /etc/crontab || true

#upgrade the script folder on many remote machines with the one on the local machine
for machine in "${targets[@]}"; do # loop over all machines
	 echo "------------------------------------"
	 echo "        " $user@$machine			# show current machine to the user for the correct sudo password
	 echo "------------------------------------"
	 [[ $(ssh $user@$machine rsync --version)  ]] || error rsync is missing on machine "$machine". aborting.
	 ssh $user@$machine [ -d $inbox ] ||  ssh -tt $user@$machine "sudo -- bash -c 'mkdir -p $inbox && chown user:user $inbox'" #check if remote inbox exists || creates
	 ssh $user@$machine [ -d $backup ] ||  ssh -tt $user@$machine "sudo -- bash -c 'mkdir -p $backup && chown root:root $backup'" #check if remote backup exists || creates
	 ssh $user@$machine [ -d $scripts ] ||  ssh -tt $user@$machine "sudo -- bash -c 'mkdir -p $scripts && chown root:root $scripts'" #check if remote script exists || creates
	 rsync -avx --delete $inbox/ $user@$machine:$inbox/ # copy scripts to remote machine
	 ssh -tt $user@$machine "sudo -- bash -c 'rsync -av --delete --backup --backup-dir=$backup $inbox/ $scripts/ && chown -R root:root $scripts && /scripts/service-reloader.bsh && cp /scripts/crontab /etc/crontab'"
done
info 3 all servers updated
