[Unit]
Description=Run /scripts/cronjobs.bsh shutdown at shutdown
Requires=network.target
DefaultDependencies=no
Before=shutdown.target reboot.target

[Service]
Type=oneshot
RemainAfterExit=true
ExecStart=sudo -u user lxc-start -n services-lxc-test
ExecStop=sudo -u user lxc-start -n services-lxc-test

[Install]
WantedBy=multi-user.target
