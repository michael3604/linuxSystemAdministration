[Unit]
Description=manages exclusive write requests to the backup hdd.
After=network-online.target

[Service]
Type=simple
User=root
ExecStart=/scripts/lib/requesthandler.bsh --request backup-hdd,write --exclusive --needs-sudo
KillMode=process
TimeoutSec=30
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target