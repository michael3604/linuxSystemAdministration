#!/usr/bin/env bash
# ============================================================
# argParser.lib.bsh
# Reusable argument parser for operational bash scripts
# Supports:
#   - short and long options
#   - bundled short flags (-vx)
#   - short values (-r /repo or -r/repo or -rVALUE)
#   - long values (--repo /repo or --repo=/repo)
#   - required and defaulted values
#   - positional parameters
#   - strict mode (set -euo pipefail)
# ============================================================

# ============================================================
# Internal storage
# ============================================================

# associative arrays describing arguments
# key = long argument name

declare -Ag __ARG_TYPE=()       # bool | value
declare -Ag __ARG_SHORT=()      # short option character
declare -Ag __ARG_HELP=()       # help text
declare -Ag __ARG_REQUIRED=()   # "true" if required
declare -Ag __ARG_DEFAULT=()    # default value

# positional argument storage

declare -ag __ARG_POSITIONAL=()       # values found during parsing
declare -ag __ARG_POSITIONAL_NAMES=() # declared positional variable names

# ============================================================
# Definition API
# ============================================================

argDefineBool() {
    local name="$1"
    local short="$2"
    local help="$3"

    __ARG_TYPE["$name"]="bool"
    __ARG_SHORT["$name"]="$short"
    __ARG_HELP["$name"]="$help"
    __ARG_REQUIRED["$name"]="false"
    __ARG_DEFAULT["$name"]="0"

    eval "$name=0"  # create variable in caller namespace
}

argDefineValue() {
    local name="$1"
    local short="$2"
    local help="$3"
    local modifier="$4"

    __ARG_TYPE["$name"]="value"
    __ARG_SHORT["$name"]="$short"
    __ARG_HELP["$name"]="$help"

    if [[ "$modifier" == "required" ]]; then
        __ARG_REQUIRED["$name"]="true"
        __ARG_DEFAULT["$name"]=""

    # ${modifier#default=} removes the prefix "default=" from the string
    # Example: "default=7" -> "7"
    elif [[ "$modifier" =~ ^default= ]]; then
        __ARG_REQUIRED["$name"]="false"
        __ARG_DEFAULT["$name"]="${modifier#default=}"

    else
        __ARG_REQUIRED["$name"]="false"
        __ARG_DEFAULT["$name"]=""
    fi

    # initialize variable with default value
    eval "$name=\"${__ARG_DEFAULT[$name]}\""
}

argPositionalParameters() {
    # store names of positional parameters
    __ARG_POSITIONAL_NAMES=("$@")
}

# ============================================================
# Help Generator
# ============================================================

arg_print_help() {
    local script
    script="$(basename "$0")"

    echo "Usage: $script [options] ${__ARG_POSITIONAL_NAMES[*]}"
    echo

    if [[ ${#__ARG_TYPE[@]} -gt 0 ]]; then

        echo "Options:"

        for name in "${!__ARG_TYPE[@]}"; do

            local short="${__ARG_SHORT[$name]}"
            local help="${__ARG_HELP[$name]}"
            local required="${__ARG_REQUIRED[$name]}"
            local default="${__ARG_DEFAULT[$name]}"

            local short_part=""
            [[ -n "$short" ]] && short_part="-$short, "

            local type="${__ARG_TYPE[$name]}"

            local value_part=""
            [[ "$type" == "value" ]] && value_part=" <value>"

            printf "  %s--%s%s\n" "$short_part" "$name" "$value_part"
            printf "      %s" "$help"

            if [[ "$required" == "true" ]]; then
                printf " (required)"

            elif [[ -n "$default" ]]; then
                printf " (default: %s)" "$default"
            fi

            echo
            echo
        done

        echo
    fi

    if [[ ${#__ARG_POSITIONAL_NAMES[@]} -gt 0 ]]; then

        echo "Positional parameters:"

        for pname in "${__ARG_POSITIONAL_NAMES[@]}"; do
            echo "  $pname"
        done

        echo
    fi
}

# ============================================================
# Parsing
# ============================================================

argParse() {

    while [[ $# -gt 0 ]]; do

        case "$1" in

            --help|-h)
                arg_print_help
                exit 0
                ;;

            # long option with inline value
            # Example: --repo=/tank/borg

            --*=*)

                local opt="${1%%=*}"  # remove everything after first '='
                local val="${1#*=}"   # remove everything up to first '='

                # ${opt#--} removes the leading "--"
                opt="${opt#--}"

                __arg_set_long "$opt" "$val"

                shift
                ;;

            # long option without inline value

            --*)

                local opt="${1#--}"   # remove "--" prefix

                if [[ -n "${__ARG_TYPE[$opt]+x}" && "${__ARG_TYPE[$opt]}" == "value" ]]; then

                    shift

                    [[ -z "$1" ]] && __arg_error "Option --$opt requires a value (see also --help)"

                    __arg_set_long "$opt" "$1"

                    shift

                else

                    __arg_set_long "$opt" 1

                    shift
                fi

                ;;

            # short options or bundles

            -*)

                local token="${1#-}"  # remove leading '-'

                shift

                while [[ -n "$token" ]]; do

                    local c="${token:0:1}"   # first character
                    token="${token:1}"      # remove first character

                    local name=""

                    for n in "${!__ARG_SHORT[@]}"; do
                        if [[ "${__ARG_SHORT[$n]}" == "$c" ]]; then
                            name="$n"
                            break
                        fi
                    done

                    [[ -z "$name" ]] && __arg_error "Unknown argument -$c (see also --help)"

                    if [[ "${__ARG_TYPE[$name]}" == "bool" ]]; then

                        eval "$name=1"
                        continue
                    fi

                    # value option

                    local value=""

                    if [[ -n "$token" ]]; then

                        # case: -rVALUE
                        value="$token"
                        token=""

                    else

                        # case: -r VALUE

                        [[ -z "$1" ]] && __arg_error "Option -$c requires a value (see also --help)"

                        value="$1"
                        shift
                    fi

                    eval "$name=\"$value\""
                done
                ;;

            *)

                # collect positional arguments
                __ARG_POSITIONAL+=("$1")

                shift
                ;;

        esac

    done

    __arg_validate_required

    __arg_assign_positionals
}

# ============================================================
# Internal Helpers
# ============================================================

__arg_set_long() {

    local name="$1"
    local value="$2"

    # ${array[key]+x} checks existence of a key without triggering set -u

    if [[ -z "${__ARG_TYPE[$name]+x}" ]]; then
        __arg_error "Unknown argument --$name (see also --help)"
    fi

    if [[ "${__ARG_TYPE[$name]}" == "bool" ]]; then

        eval "$name=1"

    else

        eval "$name=\"$value\""
    fi
}

__arg_validate_required() {

    local name

    for name in "${!__ARG_REQUIRED[@]}"; do

        if [[ "${__ARG_REQUIRED[$name]}" == "true" ]]; then

            local val

            # indirect variable expansion
            eval "val=\"\$$name\""

            [[ -z "$val" ]] && __arg_error "Missing required option --$name (see also --help)"
        fi
    done
}

__arg_assign_positionals() {

    local expected_count="${#__ARG_POSITIONAL_NAMES[@]}"  # number declared
    local actual_count="${#__ARG_POSITIONAL[@]}"          # number provided

    if [ "$actual_count" -gt "$expected_count" ]; then
        __arg_error "Too many positional parameters (see also --help)"
    fi

    local i=0

    while [ "$i" -lt "$expected_count" ]; do

        local pname="${__ARG_POSITIONAL_NAMES[$i]}"

        # ${array[index]-} returns empty if element does not exist
        # this prevents "unbound variable" errors with set -u

        local pval="${__ARG_POSITIONAL[$i]-}"

        if [ -z "$pval" ]; then
            __arg_error "Missing positional parameter $pname (see also --help)"
        fi

        printf -v "$pname" '%s' "$pval"

        i=$((i+1))

    done
}

__arg_error() {

    echo "Argument error: $1" >&2

    exit 2
}

# ============================================================
# Optional test harness
# ============================================================

# Run with:
#   bash argParser.lib.bsh --selftest

if [[ "${1-}" == "--selftest" ]]; then

    echo "Running argParser self‑test"

    test_script() {

        source "$0"

        argDefineBool "verbose" "v" "verbose"
        argDefineValue "repo" "r" "repo" required
        argDefineValue "retention" "t" "retention" default=7

        argPositionalParameters target source

        argParse "$@"

        echo "verbose=$verbose"
        echo "repo=$repo"
        echo "retention=$retention"
        echo "target=$target"
        echo "source=$source"
    }

    echo
    echo "Test 1"
    test_script -v -r /repo -t44 host path

    echo
    echo "Test 2"
    test_script -vr/repo host path

    echo
    echo "Test 3"
    test_script --repo=/repo host path

    exit 0
fi
