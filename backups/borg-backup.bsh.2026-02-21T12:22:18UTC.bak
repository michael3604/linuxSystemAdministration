#!/usr/bin/env bash
set -euo pipefail

############################################
# CONFIG
############################################

DATASET_NC="tank/nextcloudData"
DATASET_MEDIA="tank/mediaPool"

SNAPNAME="borg"
RUNFILE="/run/backup-borg-requested"

MOUNT_BASE="/mnt/borg"
MOUNT_NC="$MOUNT_BASE/nextcloudData"
MOUNT_MEDIA="$MOUNT_BASE/mediaPool"

DATEFILE="$MOUNT_BASE/date"

PASSPHRASE_FILE="/root/keyfiles/borg/main.borgPassphrase"

BORG_RSH="ssh -J user@mainssh -p 45022"

REPO_DATA="user@localhost:/mnt/backupHDD/borgBackup/main/data"
REPO_MEDIA="user@localhost:/mnt/backupHDD/borgBackup/main/media"

RETRY_DELAY=60

# Retention policy
KEEP_DAILY=21
KEEP_WEEKLY=8
KEEP_MONTHLY=12
KEEP_YEARLY=5

BORG_OPTS_COMMON=(
    --verbose
    --stats
    --compression lz4
    --list
    --filter AME
)

############################################
# HELPERS
############################################

log() {
    echo "[ $(date -u +"%Y-%m-%dT%H:%M:%SZ") ] $*"
}

error() {
    echo "[ $(date -u +"%Y-%m-%dT%H:%M:%SZ") ] $*"
    /scripts/pushover.bsh "$0" "$*"
}

ensure_dirs() {
    mkdir -p "$MOUNT_NC" "$MOUNT_MEDIA"
}

borg_env() {
    export BORG_PASSCOMMAND="cat $PASSPHRASE_FILE"
    export BORG_RSH
}

interrupt_stray_borg() {
    log "Checking for running borg backup processes..."

    rm "$RUNFILE" 2> /dev/null || true # to stop retries
    if [[ -f "$RUNFILE" ]] ; then
       error "runfile $RUNFILE still exists."
    fi
    # pattern unique to your repos
    pattern="borg create .*backupHDD/borgBackup/main"

    mapfile -t pids < <(pgrep -f "$pattern" || true)

    if [[ ${#pids[@]} -eq 0 ]]; then
        log "No running borg processes found."
        return
    fi

    /scripts/pushover.bsh "borg backup was terminated."

    log "Found ${#pids[@]} borg process(es): ${pids[*]}"

    for pid in "${pids[@]}"; do
        log "Sending SIGINT to borg PID $pid"
        kill -SIGINT "$pid" 2>/dev/null || true
    done

    log "Waiting for borg processes to exit cleanly..."

    for pid in "${pids[@]}"; do
        while kill -0 "$pid" 2>/dev/null; do
            sleep 2
        done
        log "PID $pid exited."
    done

    log "All similar borg processes have been interupted cleanly"
}

safe_umount() {
    umount "$MOUNT_NC" 2>/dev/null || true
    umount "$MOUNT_MEDIA" 2>/dev/null || true
}

destroy_snapshots() {
    log "Destroying old snapshots"
    zfs destroy -r "${DATASET_NC}@${SNAPNAME}" 2>/dev/null || true
    zfs destroy -r "${DATASET_MEDIA}@${SNAPNAME}" 2>/dev/null || true
}

create_snapshots() {
    log "Creating snapshots"
    zfs snapshot "${DATASET_NC}@${SNAPNAME}"
    zfs snapshot "${DATASET_MEDIA}@${SNAPNAME}"
}

mount_snapshots() {
    log "Mounting snapshots"
    mount -t zfs "${DATASET_NC}@${SNAPNAME}" "$MOUNT_NC"
    mount -t zfs "${DATASET_MEDIA}@${SNAPNAME}" "$MOUNT_MEDIA"
}

check_remote_space() {
    # Minimum required space in GB
    local min_gb=200
    local remote_host="user@localhost"
    local jumphost="user@mainssh"
    local remote_path="/mnt/backupHDD"

    log "Checking available space on remote $remote_host:$remote_path via jumphost $jumphost..."

    # Get free space in GB using SSH
    free_gb=$(ssh -J "$jumphost" "$remote_host" -p 45022 df -BG --output=avail "$remote_path" | tail -n1 | tr -d 'G' )

    if [[ -z "$free_gb" ]]; then
        error "Could not determine free space on remote!"
    fi

    if (( free_gb < min_gb )); then
        error "Not enough free space on remote ($free_gb GB < $min_gb GB)"
    fi

    log "Remote free space OK: ${free_gb} GB available."
}

validate_repo() {
    local repo_name="$1"  # REPO_DATA or REPO_MEDIA

    log "Validating Borg repository $repo_name on $REMOTE_HOST via jump host $JUMPHOST..."

    ssh -J "$JUMPHOST" "$REMOTE_HOST" -p "$SSH_PORT" \
        BORG_PASSPHRASE_FILE="$BORG_PASSPHRASE_FILE" \
        borg check --read-only "$repo_name"

    if [[ $? -ne 0 ]]; then
        log "ERROR: Borg repository validation failed for $repo_name"
        exit 1
    fi

    log "Borg repository $repo_name is valid."
}

prune_repo() {
    local repo_name="$1"   # REPO_DATA or REPO_MEDIA
    local prefix="$2"      # archive prefix for this repo

    log "Pruning Borg repository $repo_name (prefix: $prefix)..."

    ssh -J "$JUMPHOST" "$REMOTE_HOST" -p "$SSH_PORT" \
        BORG_PASSPHRASE_FILE="$BORG_PASSPHRASE_FILE" \
        borg prune --prefix "$prefix" \
            --keep-daily "$KEEP_DAILY" \
            --keep-weekly "$KEEP_WEEKLY" \
            --keep-monthly "$KEEP_MONTHLY" \
            --keep-yearly "$KEEP_YEARLY" \
            --list \
            "$repo_name"

    log "Pruning completed for $repo_name."
}

############################################
# COMMANDS
############################################

cmd_prepare() {
    log "=== PREPARE PHASE ==="

    rm -f "$DATEFILE"

    safe_umount

    destroy_snapshots

    log "Prepare phase complete"
}

cmd_snapshot() {
    log "=== SNAPSHOT PHASE ==="

    ensure_dirs

    create_snapshots

    date -u +"%Y-%m-%dT%H:%M:%SZ" > "$DATEFILE"

    log "Snapshot timestamp: $(cat "$DATEFILE")"

    mount_snapshots
}

cmd_backup() {
    log "=== BACKUP PHASE ==="

    borg_env

    if [[ ! -f "$DATEFILE" ]]; then
        error "date file missing"
    fi

    for mp in "$MOUNT_MEDIA" "$MOUNT_NC"; do
        if ! mountpoint -q "$mp"; then
            error "$mp is not mounted!"
        else
            log "Mountpoint OK: $mp"
        fi
    done


    ARCHIVE="$(cat "$DATEFILE")"

    check_remote_space
    touch "$RUNFILE" #if this file is deleted by the interrupt, retries are stopped

    ########################################
    # MAIN DATA BACKUP (FAST)
    ########################################

    log "Starting main data backup"
    while : ; do
    if borg list "$REPO_DATA::$ARCHIVE" >/dev/null 2>&1; then
        log "$REPO_DATA::$ARCHIVE already exists — assuming completed"
        break
    fi
    borg create \
        "${BORG_OPTS_COMMON[@]}" \
        "$REPO_DATA::$ARCHIVE" \
        "$MOUNT_BASE" \
        --exclude "$MOUNT_MEDIA/media" \
        && touch /var/lib/successFiles/"$0".data \
        && break
        if [[ -f "$RUNFILE" ]]; then
          log retrying shortly... Hit Ctrl+C now to abort a retry
          sleep $RETRY_DELAY
        else
          exit 1
        fi
    done

    ########################################
    # MEDIA BACKUP (LONG-RUNNING)
    ########################################

    log "Starting media backup may run multiple days"

    while : ; do
    if borg list "$REPO_MEDIA::$ARCHIVE" >/dev/null 2>&1; then
        log "$REPO_MEDIA::$ARCHIVE already exists — assuming completed"
        break
    fi
    borg create \
        "${BORG_OPTS_COMMON[@]}" \
        --files-cache=mtime,size \
        --checkpoint-interval 1800 \
        "$REPO_MEDIA::$ARCHIVE" \
        "$MOUNT_MEDIA/media" \
       && touch /var/lib/successFiles/"$0".media \
       && break
        if [[ -f "$RUNFILE" ]]; then
          log retrying shortly...
          sleep $RETRY_DELAY
        else
          exit 1
        fi
    done


}

cmd_validate_remote_repo() {
  log "warning, untested"
  validate_remote_repo "$REPO_DATA"
  validate_remote_repo "$REPO_MEDIA"
}

cmd_prune() {
  log "warning, untested"
  prune_repo "$REPO_DATA"
  prune_repo "$REPO_MEDIA"
}

############################################
# ENTRYPOINT
############################################

case "${1:-}" in
    prepare|"-pre")
        interrupt_stray_borg
        cmd_prepare
        ;;
    snapshot|"-s")
        interrupt_stray_borg
        cmd_snapshot
        ;;
    backup|"-b")
        interrupt_stray_borg
        cmd_backup
        ;;
    interrupt|"-i")
        interrupt_stray_borg
        ;;
    validate|"-v")
        cmd_validate_remote_repo
        ;;
    prune|"-pru")
        cmd_prune
        ;;
    *)
        echo "Usage: $0 {prepare|snapshot|backup|interrupt}"
        exit 1
        ;;
esac
