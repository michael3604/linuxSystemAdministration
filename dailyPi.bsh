#!/bin/bash

source $(dirname "$0")/lib/lock.lib.bsh
source $(dirname "$0")/lib/messages.lib.bsh
source $(dirname "$0")/lib/success.lib.bsh
set +e #continue even after errors

lock
/scripts/freeSpace.bsh || err "free space error, aborting script"

mkdir -p /var/log/nmrCloud


inf "=== system maintenance ==="
#ToDo: system backup to main
inf deleting old log files
find /var/log/nmrCloud/ -type f -mtime +30 -delete
/scripts/os-upgrader.bsh
success
inf "$0 completed"
